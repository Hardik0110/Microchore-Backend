# Microchore Backend Configuration Environment Variables

# Security
SECRET_KEY=django-insecure-development-secret-key-change-in-production
DEBUG=True

# ALLOWED_HOSTS
# Local dev: localhost,127.0.0.1
# Cloudflare quick tunnel: add .trycloudflare.com (leading dot = wildcard subdomain)
# Named tunnel on your own domain: add api.yourdomain.com
ALLOWED_HOSTS=localhost,127.0.0.1,.trycloudflare.com

# Database (Postgres on Railway, falls back to SQLite locally)
# DATABASE_URL=postgres://user:password@host:port/dbname

# CORS
# Comma-separated list of frontend origins that may call the API.
# Example for Vercel demo:
#   CORS_ALLOWED_ORIGINS=https://microchore-frontend.vercel.app,http://localhost:5173
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Frontend / backend base URLs (used by OAuth callbacks + email links)
# For the Vercel demo, set FRONTEND_BASE_URL to your Vercel preview/prod URL.
FRONTEND_BASE_URL=http://localhost:5173
BACKEND_BASE_URL=http://127.0.0.1:8000

# Realtime (Redis on Railway, falls back to InMemory locally)
# REDIS_URL=redis://127.0.0.1:6379/0
